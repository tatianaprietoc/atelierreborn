# Copia este archivo a .env (o exporta las variables en tu shell) y ajusta los valores.

# Contraseña única de acceso a la app.
APP_PASSWORD=changeme

# Clave usada para firmar la sesión de Flask. Cambia esto por un valor aleatorio propio.
SECRET_KEY=change-this-to-a-random-value

# true = pide la contraseña en un login. false = deja entrar a cualquiera (útil para
# pruebas compartidas, no recomendado para uso real con datos sensibles).
REQUIRE_PASSWORD=true

# Puerto en el que corre el servidor.
PORT=5050
